# Beyond Kw — environment template. Copy to .env.local and fill in your values.
# Find these in the Supabase dashboard: Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_anon_key

# Google Maps JavaScript API + Places API key (console.cloud.google.com)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
